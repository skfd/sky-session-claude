<Window x:Class="SessionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SessionApp"
        Title="Claude Code sessions — double-click to resume · A: hide/show completed · R: refresh"
        Height="720" Width="1200" WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Wrapping text cell for the prompt/recap columns. -->
        <Style x:Key="WrapCell" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="TopCell" TargetType="TextBlock">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="Grid" Grid.Row="0"
                  ItemsSource="{Binding RowsView}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended" SelectionUnit="FullRow"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserAddRows="False" CanUserResizeRows="False"
                  RowHeaderWidth="0" VerticalScrollBarVisibility="Auto"
                  MouseDoubleClick="Grid_MouseDoubleClick">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <!-- Tint unfinished rows pale amber so the eye lands on them. -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Complete}" Value="False">
                            <Setter Property="Background" Value="#FFF8E1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Last active" Binding="{Binding LastActiveDisplay}"
                                    ElementStyle="{StaticResource TopCell}" Width="Auto"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}"
                                    ElementStyle="{StaticResource TopCell}" Width="Auto"/>
                <DataGridTextColumn Header="Project" Binding="{Binding Project}"
                                    ElementStyle="{StaticResource TopCell}" Width="Auto"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}"
                                    ElementStyle="{StaticResource TopCell}" Width="Auto"/>
                <DataGridTextColumn Header="Ctx%" Binding="{Binding CtxDisplay}"
                                    ElementStyle="{StaticResource TopCell}" Width="Auto"/>
                <DataGridTextColumn Header="Last prompt" Binding="{Binding LastPrompt}"
                                    ElementStyle="{StaticResource WrapCell}" Width="34*"/>
                <DataGridTextColumn Header="Agent recap" Binding="{Binding Recap}"
                                    ElementStyle="{StaticResource WrapCell}" Width="46*"/>
                <DataGridTextColumn Header="KB" Binding="{Binding SizeKB}"
                                    ElementStyle="{StaticResource TopCell}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Filter bar + actions, docked at the bottom. -->
        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="0,1,0,0" Background="#F7F7F7">
            <StackPanel Margin="8,6">
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="SearchBox" Width="220" Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"/>

                    <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="130" Margin="0,0,12,0" VerticalAlignment="Center"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding StatusFilter}"/>

                    <TextBlock Text="Project:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="180" Margin="0,0,12,0" VerticalAlignment="Center"
                              ItemsSource="{Binding ProjectOptions}"
                              SelectedItem="{Binding ProjectFilter}"/>

                    <CheckBox Content="Hide completed" VerticalAlignment="Center" Margin="0,0,12,0"
                              IsChecked="{Binding HideCompleted}"/>
                    <CheckBox Content="All projects" VerticalAlignment="Center" Margin="0,0,12,0"
                              IsChecked="{Binding AllProjects}"/>

                    <TextBlock Text="Show:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="70" Margin="0,0,12,0" VerticalAlignment="Center"
                              ItemsSource="{Binding TopOptions}"
                              SelectedItem="{Binding TopSelection}"
                              ToolTip="Max sessions to load (older 1M sessions may need a larger cap)"/>

                    <CheckBox Content="Live" VerticalAlignment="Center" Margin="0,0,12,0"
                              IsChecked="{Binding LiveUpdates}"
                              ToolTip="Auto-refresh when a session transcript changes"/>
                </WrapPanel>

                <DockPanel Margin="0,6,0,0">
                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                               Foreground="#666" Text="{Binding StatusLine}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Refresh (R)" Padding="10,4" Margin="0,0,8,0"
                                Command="{Binding RefreshCommand}"/>
                        <Button x:Name="CopyBtn" Content="Copy resume command(s)" Padding="10,4"
                                Click="CopyBtn_Click"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
