<Window x:Class="SessionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SessionApp"
        Title="Claude Code sessions — double-click to resume · A: hide/show completed · R: refresh"
        Height="720" Width="1200" WindowStartupLocation="CenterScreen"
        FontSize="14" Foreground="#1A1A1A"
        TextOptions.TextFormattingMode="Display"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Card row. Fixed height: long recaps are clipped, never stretch the row. -->
        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="#D8DBDF" BorderThickness="0,0,0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F7FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CFE0F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BarLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#33383D"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter bar + actions, one row across the top. -->
        <Border Grid.Row="0" BorderBrush="#B9BDC2" BorderThickness="0,0,0,1" Background="#F2F3F4">
            <DockPanel Margin="8,7">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button Content="Refresh (R)" Padding="12,5" Margin="0,0,6,0"
                            Command="{Binding RefreshCommand}"/>
                    <Button x:Name="CopyBtn" Content="Copy resume command(s)" Padding="12,5"
                            Click="CopyBtn_Click"/>
                </StackPanel>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Search:" Style="{StaticResource BarLabel}"/>
                    <TextBox x:Name="SearchBox" Width="200" Margin="0,0,10,0"
                             VerticalAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"/>

                    <ComboBox Width="140" Margin="0,0,6,0" VerticalAlignment="Center"
                              ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding StatusFilter}"/>
                    <ComboBox Width="172" Margin="0,0,10,0" VerticalAlignment="Center"
                              ItemsSource="{Binding ProjectOptions}"
                              SelectedItem="{Binding ProjectFilter}"/>

                    <CheckBox Content="Hide completed" VerticalAlignment="Center" Margin="0,0,10,0"
                              IsChecked="{Binding HideCompleted}"/>
                    <CheckBox Content="All projects" VerticalAlignment="Center" Margin="0,0,10,0"
                              IsChecked="{Binding AllProjects}"/>
                    <CheckBox Content="Live" VerticalAlignment="Center" Margin="0,0,10,0"
                              IsChecked="{Binding LiveUpdates}"
                              ToolTip="Auto-refresh when a session file changes"/>

                    <TextBlock Text="Show:" Style="{StaticResource BarLabel}"/>
                    <ComboBox Width="78" VerticalAlignment="Center"
                              ItemsSource="{Binding TopOptions}"
                              SelectedItem="{Binding TopSelection}"
                              ToolTip="Max sessions to load (older 1M sessions may need a larger cap)"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <ListBox x:Name="Grid" Grid.Row="1"
                 ItemsSource="{Binding RowsView}"
                 SelectionMode="Extended"
                 BorderThickness="0" Background="White"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemContainerStyle="{StaticResource CardItem}"
                 MouseDoubleClick="Grid_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Height="126">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status accent stripe; transparent for completed sessions. -->
                        <Rectangle Grid.Column="0" Fill="{Binding StatusBrush}"/>

                        <Grid Grid.Column="1" Margin="10,7,10,7">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Title line: name on the left, project + age on the right. -->
                            <DockPanel Grid.Row="0">
                                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                           Margin="10,0,0,0" Foreground="#4A5260">
                                    <Run Text="{Binding Project, Mode=OneWay}" Foreground="#3B4351"/>
                                    <Run Text="·"/>
                                    <Run Text="{Binding RelativeAge, Mode=OneWay}"
                                         ToolTip="{Binding Timestamp}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"
                                           Foreground="#141414" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>

                            <TextBlock Grid.Row="1" Text="{Binding LastPrompt}" Margin="0,3,0,0"
                                       FontStyle="Italic" Foreground="#4A5260"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding LastPrompt}"/>

                            <!-- Two lines of recap, hard-clipped; hover for the rest. -->
                            <TextBlock Grid.Row="2" Text="{Binding Recap}" Margin="0,2,0,0"
                                       Height="40" TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       LineHeight="20" LineStackingStrategy="BlockLineHeight"
                                       Foreground="#2A2A2A">
                                <TextBlock.ToolTip>
                                    <ToolTip MaxWidth="520">
                                        <TextBlock Text="{Binding Recap}" TextWrapping="Wrap" FontSize="14"/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>

                            <TextBlock Grid.Row="3" Text="{Binding MetaLine}" Margin="0,2,0,0"
                                       FontSize="12.5" Foreground="#4A5260"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" BorderBrush="#B9BDC2" BorderThickness="0,1,0,0" Background="#F2F3F4">
            <TextBlock Margin="10,5" Foreground="#33383D" Text="{Binding StatusLine}"/>
        </Border>
    </Grid>
</Window>
